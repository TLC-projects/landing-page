---
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import AccessibilityButton from '@components/ui/AccessibilityButton';
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Centro de Entrenamiento y Aprendizaje de Idiomas TLC - Programas de inglés, francés y capacitación docente"
    />
    <title>Centro de entrenamiento & Aprendizaje de idiomas tlc</title>
  </head>
  <body class="bg-background text-gray-900">
    <!-- Skip to main content link for keyboard users -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent-600 focus:text-white focus:rounded-md focus:shadow-lg"
    >
      Saltar al contenido principal
    </a>

    <div id="root">
      <Header />
      <main id="main-content" role="main" tabindex="-1">
        <slot />
      </main>
      <Footer />
      <AccessibilityButton client:load />
    </div>
  </body>

  <style>
    #root {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    main {
      flex: 1;
    }

    @supports (height: 100svh) {
      body {
        min-height: 100svh;
      }

      #root {
        min-height: 100svh;
      }
    }
  </style>
</html>
