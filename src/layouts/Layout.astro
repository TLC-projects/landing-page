---
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import '../styles/global.css';
import '../styles/a11y.css'
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/assets/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Centro de Entrenamiento y Aprendizaje de Idiomas TLC - Programas de inglés, francés y capacitación docente"
    />
    <title>Centro de entrenamiento & Aprendizaje de idiomas tlc</title>
  </head>
  <body class="bg-background text-gray-700">
    <div id="root" class="flex flex-col">
      <Header />
      <main id="main-content" role="main" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>

  <style>
    body, #root {
      min-height: 100vh;
    }

    main {
      flex: 1;
    }

    @supports (height: 100svh) {
      body {
        min-height: 100svh;
      }

      #root {
        min-height: 100svh;
      }
    }
  </style>
</html>
