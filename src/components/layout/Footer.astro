---
import { Facebook, Twitter, Instagram, MessageCircle } from 'lucide-react';
---

<footer class="bg-primary-900 text-white py-12">
  <div class="u-wrapper mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="flex items-start gap-3 mb-4">
        <img
          src="/assets/base/logo-dark.webp"
          alt="Logo del centro de entrenamiento & aprendizaje de idiomas tlc"
          class="h-10 md:h-18 w-auto"
        />
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4">Enlaces rápidos</h3>
        <ul class="space-y-2">
          <li>
            <a href="/inscripcion" class="text-secondary-300 hover:text-secondary-100 transition-colors text-sm">
              Inscripciones
            </a>
          </li>
          <li>
            <a
              href="/bienestar-academico"
              class="text-secondary-300 hover:text-secondary-100 transition-colors text-sm"
            >
              Bienestar académico
            </a>
          </li>
          <li>
            <a
              href="/quienes-somos/#politicas-institucionales"
              class="text-secondary-300 hover:text-secondary-100 transition-colors text-sm"
            >
              Políticas institucionales
            </a>
          </li>
          <li>
            <a
              href="/quienes-somos/#estructura-organizacional"
              class="text-secondary-300 hover:text-secondary-100 transition-colors text-sm"
            >
              Estructura organizacional TLC
            </a>
          </li>
          <li>
            <a
              href="https://booksandbooksdigital.com.co/moodleOvas/login/index.php"
              class="text-secondary-300 hover:text-secondary-100 transition-colors text-sm"
            >
              Campus virtual
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4">Contáctanos</h3>
        <div class="space-y-3 text-sm">
          <div>
            <div class="font-medium text-secondary-200">Servicio al cliente:</div>
            <div class="text-secondary-300">(601) 000 00 00 EXT 0</div>
            <a
              href="mailto:servicliente@ceaitlc.com.co"
              class="text-secondary-300 hover:text-secondary-100 transition-colors"
            >
              servicliente@ceaitlc.com.co
            </a>
          </div>
          <div>
            <div class="font-medium text-secondary-200">Sugerencias quejas o reclamos</div>
            <a
              href="mailto:servicliente@ceaitlc.com.co"
              class="text-secondary-300 hover:text-secondary-100 transition-colors"
            >
              servicliente@ceaitlc.com.co
            </a>
          </div>
          <div>
            <div class="font-medium text-secondary-200">Ayuda</div>
            <a
              href="mailto:servicliente@ceaitlc.com.co"
              class="text-secondary-300 hover:text-secondary-100 transition-colors"
            >
              servicliente@ceaitlc.com.co
            </a>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4">Síguenos</h3>
        <div class="flex gap-4">
          <a
            href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary-300 hover:text-secondary-100 transition-colors"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="currentColor" viewBox="0 0 256 256">
              <path
                d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm8,191.63V152h24a8,8,0,0,0,0-16H136V112a16,16,0,0,1,16-16h16a8,8,0,0,0,0-16H152a32,32,0,0,0-32,32v24H96a8,8,0,0,0,0,16h24v63.63a88,88,0,1,1,16,0Z"
              >
              </path>
            </svg>
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary-300 hover:text-secondary-100 transition-colors"
            aria-label="Twitter"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" viewBox="0 0 256 256">
              <path
                d="M214.75,211.71l-62.6-98.38,61.77-67.95a8,8,0,0,0-11.84-10.76L143.24,99.34,102.75,35.71A8,8,0,0,0,96,32H48a8,8,0,0,0-6.75,12.3l62.6,98.37-61.77,68a8,8,0,1,0,11.84,10.76l58.84-64.72,40.49,63.63A8,8,0,0,0,160,224h48a8,8,0,0,0,6.75-12.29ZM164.39,208,62.57,48h29L193.43,208Z"
              >
              </path>
            </svg>
          </a>
          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary-300 hover:text-secondary-100 transition-colors"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" viewBox="0 0 256 256">
              <path
                d="M128,80a48,48,0,1,0,48,48A48.05,48.05,0,0,0,128,80Zm0,80a32,32,0,1,1,32-32A32,32,0,0,1,128,160ZM176,24H80A56.06,56.06,0,0,0,24,80v96a56.06,56.06,0,0,0,56,56h96a56.06,56.06,0,0,0,56-56V80A56.06,56.06,0,0,0,176,24Zm40,152a40,40,0,0,1-40,40H80a40,40,0,0,1-40-40V80A40,40,0,0,1,80,40h96a40,40,0,0,1,40,40ZM192,76a12,12,0,1,1-12-12A12,12,0,0,1,192,76Z"
              >
              </path>
            </svg>
          </a>
          <a
            href="https://wa.me/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-secondary-300 hover:text-secondary-100 transition-colors"
            aria-label="WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" viewBox="0 0 256 256">
              <path
                d="M187.58,144.84l-32-16a8,8,0,0,0-8,.5l-14.69,9.8a40.55,40.55,0,0,1-16-16l9.8-14.69a8,8,0,0,0,.5-8l-16-32A8,8,0,0,0,104,64a40,40,0,0,0-40,40,88.1,88.1,0,0,0,88,88,40,40,0,0,0,40-40A8,8,0,0,0,187.58,144.84ZM152,176a72.08,72.08,0,0,1-72-72A24,24,0,0,1,99.29,80.46l11.48,23L101,118a8,8,0,0,0-.73,7.51,56.47,56.47,0,0,0,30.15,30.15A8,8,0,0,0,138,155l14.61-9.74,23,11.48A24,24,0,0,1,152,176ZM128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a87.87,87.87,0,0,1-44.06-11.81,8,8,0,0,0-6.54-.67L40,216,52.47,178.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Z"
              >
              </path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
