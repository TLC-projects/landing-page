---
import { Button } from '../button';

interface Props {
  title: string;
  duration: string;
  img: string;
  buttonText?: string;
  buttonLink?: string;
}

const { title, duration, img, buttonText = 'Más información', buttonLink = '#' } = Astro.props;
---

<article class="overflow-hidden flex flex-col">
  <div class="aspect-video overflow-hidden">
    <img src={img} alt={title} class="w-full h-full object-cover" />
  </div>

  <div class="py-3 px-1 grid justify-items-start gap-4">
    <h3 class="text-xl md:text-xl font-semibold  min-h-14 flex items-start">
      {title}
    </h3>

    <p class="text-secondary-500 text-sm uppercase tracking-wide">
      {duration}
    </p>

    <a href={buttonLink} aria-label={`Más información sobre ${title}`}>
      <Button style={{borderRadius: "20px", fontWeight: "normal"}}> {buttonText} </Button>
    </a>
  </div>
</article>


