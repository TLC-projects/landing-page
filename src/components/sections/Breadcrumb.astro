---
import { ChevronRight } from 'lucide-react';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm self-start">
  <ol class="flex flex-wrap items-center gap-2 text-secondary-600">

    {items.map((item, index) => (
      <>
        <li class="flex items-center gap-2">

          {item.href ? (
            <a
              href={item.href}
              class="hover:text-primary-600 transition-colors"
            >
              {item.label}
            </a>
          ) : (
            <span
              aria-current="page"
              class="text-primary-700 font-semibold"
            >
              {item.label}
            </span>
          )}

        </li>

        {index < items.length - 1 && (
          <li aria-hidden="true"><ChevronRight size={16} /></li>
        )}
      </>
    ))}

  </ol>
</nav>