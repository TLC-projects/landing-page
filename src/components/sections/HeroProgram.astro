---
import { Button, Link } from '@/components/ui';

interface Props {
  programa: string;
  titulo: string;
  descripcion: string;
  imagen: string;
  reverse?: boolean;
}

const { programa, titulo, descripcion, imagen, reverse = false } = Astro.props;
---

<section
  class="relative md:h-120 h-auto flex flex-col items-center justify-between overflow-hidden text-white py-6 gap-4"
>
  <!-- Imagen de fondo -->
  <img src={imagen} alt={titulo} class="absolute inset-0 w-full h-full object-cover" />

  <!-- Contenido del héroe -->
  <div class="absolute inset-0 bg-primary-900/20"></div>
  <div
    class={`grid md:grid-cols-2 z-10 items-center mx-auto h-full md:px-12 px-4 ${reverse ? 'md:[&>*:first-child]:order-2' : ''}`}
  >
    <div class={`px-4 u-wrapper flex flex-col gap-4 max-w-2xl ${reverse ? 'md:order-2' : 'md:order-1'}`}>
      <p class="text-xl">
        {programa}
      </p>

      <h1 class="text-3xl md:text-4xl font-bold">
        {titulo}
      </h1>

      <p class="text-2xl max-w-xl">
        {descripcion}
      </p>
    </div>
    <div class={`px-4 u-wrapper flex flex-col gap-4 max-w-2xl ${reverse ? 'md:order-1' : 'md:order-2'}`}></div>
  </div>
  <div class="flex gap-8 md:flex-row flex-col z-10">
    <a href="/brochures/ingles-mundo.pdf" download>
      <Button size="lg"> Ver brochure </Button>
    </a>
    <Link href="/incripcion" size="lg"> Inscripción </Link>
    <Link href="/contactanos" size="lg"> Contáctanos </Link>
  </div>
</section>
