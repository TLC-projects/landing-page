---
import { Audio } from '@/components/ui';
import Layout from '@/layouts/Layout.astro';
import { Check } from 'lucide-react';

const criterios = [
  { text: 'Presentación de documento de identidad.' },
  { text: 'Realizar examen de clasificación de inglés.' },
  { text: 'Llenar el formato de inscripción.' },
  { text: 'Asegurar su pago mediante convenio o por pago particular.' }
];
---

<Layout title="Inscripcion">
  <Audio a11y className="mx-auto" src="/assets/audio/conoce-mas.mp3" client:only />
  <section class="bg-gray-50 overflow-visible relative lg:my-16" id="inscripciones mecanismos de admision">
    <div class="u-wrapper md:pb-6 py-6 mx-auto">
      <div class="relative grid md:grid-cols-2 gap-10 items-center justify-items-center">
        <img
          src="/assets/images/img_beneficios.webp"
          alt="Imagen de información del programa"
          class="w-md relative md:-mt-24 md:-mb-16 z-10"
        />
        <div class="flex flex-col gap-4">
          <h1 class="text-4xl font-bold">Inscripciones</h1>
          <h2 class="text-3xl font-bold">Mecanismos de admisión:</h2>
          <p>El aspirante se admite mediante los siguientes criterios:</p>
          <ul class="space-y-5">
            {
              criterios.map((criterio) => (
                <li class="flex items-start gap-4">
                  <span class="mt-0.5 flex h-6 w-6 items-center justify-center rounded-full bg-accent text-white shrink-0">
                    <Check size={14} />
                  </span>
                  <p>{criterio.text}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
  <section class="u-wrapper mx-auto py-2" id="prodecimientos de inscripciones">
    <h2 class="text-center text-4xl font-bold">Procedimiento de inscripciones:</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="border-2 flex flex-col items-center rounded-lg border-gray-300 p-6">
        <img src="/assets/icons/Paso_1.svg" alt="Imagen de información del programa" class="w-30 h-30" />
        <p class="font-bold">Registro de Información y Documentación</p>
        <ul class="list-disc mt-4 ml-4">
          <li>
            <span>Documento de Identidad (Cédula, T.I. o Pasaporte)</span>
          </li>
          <li>
            <span>Formulario de Inscripción (Digital o Físico) debidamente diligenciado.</span>
          </li>
        </ul>
      </div>
      <div class="border-2 flex flex-col items-center rounded-lg border-gray-300 p-6">
        <img src="/assets/icons/Paso_2.svg" alt="Imagen de información del programa" class="w-30 h-30" />
        <p class="font-bold">Legalización Financiera y Matrícula</p>
        <p class="text-center">Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh.</p>
      </div>
      <div class="border-2 flex flex-col items-center rounded-lg border-gray-300 p-6">
        <img src="/assets/icons/Paso_3.svg" alt="Imagen de información del programa" class="w-30 h-30" />
        <p class="font-bold">Descubrimos tu nivel:</p>
        <p class="text-center">Valoración diagnóstica sin costo</p>
      </div>
      <div class="border-2 rounded-lg flex flex-col lg:flex-row items-center gap-6 border-gray-300 p-6 col-span-1 md:col-span-2 lg:col-span-3">
        <img src="/assets/icons/Paso_4.svg" alt="Imagen de información del programa" class="w-30 h-30 shrink-0" />
        <span>
          <p class="font-bold">Inducción y Seguimiento Personalizado</p>
          <ul class="list-disc mt-4 ml-4">
            <li>
              <span><strong>Acción:</strong> Entrega de credenciales de acceso (si es virtual) o carnetización (si es presencial).</span>
            </li>
            <li>
              <span><strong>Bienvenida:</strong> Charla sobre la Actitud Mental Positiva y la importancia de la Perseverancia para alcanzar la cima (dominio del idioma).</span>
            </li>
            <li>
              <span><strong>Cargue al SIET:</strong> Registro del estudiante en el Sistema de Información de la Educación para el Trabajo.</span>
            </li>
          </ul>
        </span>
      </div>
    </div>
  </section>
</Layout>
