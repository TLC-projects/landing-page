---
import HeroProgram from '@/components/sections/HeroProgram.astro';
import ProgramFeatures from '@/components/sections/ProgramFeatures.astro';
import Layout from '@layouts/Layout.astro';
import { Check } from 'lucide-react';

const benefits = [
  'Comprender expresiones y estructuras básicas del inglés académico.',
  'Utilizar vocabulario elemental relacionado con el contexto educativo.',
  'Participar en interacciones orales simples en inglés con fines académicos.',
  'Leer y comprender textos breves de carácter educativo.',
  'Producir escritos cortos utilizando estructuras básicas del idioma.'
];
---

<Layout
  title="Programa Inglés en el Mundo"
  description="Alcanza nivel C1 en inglés con nuestro programa intensivo. Modalidad presencial, semipresencial y virtual. Metodología comunicativa con profesores certificados."
  keywords="inglés en el mundo, curso intensivo inglés, inglés C1, aprender inglés Colombia, clases de inglés, programa bilingüe, TLC inglés"
>
  <HeroProgram
    programa="Programa"
    titulo="Inglés en el Mundo"
    src="assets/audios/frances.mp3"
    descripcion="Programa de formación docente que fortalece las competencias básicas en inglés de los docentes, promoviendo el uso del idioma como herramienta para la interacción académica y pedagógica."
    imagen="/assets/images/Banner_1.webp"
  />
  <ProgramFeatures
    title="Características principales del programa"
    features={[
      {
        title: 'Descripción:',
        description:
          'Este curso de formación docente está orientado al desarrollo de competencias académicas básicas en lengua inglesa, dirigidas a docentes que se encuentran en proceso inicial de aprendizaje del idioma. A lo largo de las 20 horas, los participantes fortalecen habilidades de comprensión y producción oral y escrita mediante el estudio de estructuras lingüísticas fundamentales, vocabulario académico básico y situaciones comunicativas propias del contexto educativo. El curso se centra en el uso del inglés como herramienta para la interacción académica y pedagógica, estableciendo bases sólidas para la comprensión del idioma y su posterior profundización en niveles superiores.'
      },
      {
        title: 'Objetivo:',
        description: 'Desarrollar competencias académicas básicas en lengua inglesa que permitan a los docentes comprender y producir mensajes simples en contextos educativos.'
      }
    ]}
  />

  <section class="bg-accent-600 dark:bg-accent-700 text-white" id="beneficios">
    <div class="u-wrapper md:pb-6 py-6 mx-auto">
      <div class="relative grid md:grid-cols-2 gap-10 items-center justify-items-center">
        <img
          src="/assets/images/img_beneficios.webp"
          alt="Imagen de información del programa"
          class="md:-mt-18 mt-0 w-md"
        />
        <div class="flex flex-col gap-4">
          <h2 class="text-3xl font-bold">Desempeños</h2>
          <p>Al finalizar el curso, el docente puede:</p>
          <ul class="space-y-5">
            {
              benefits.map((benefit) => (
                <li class="flex items-start gap-4">
                  <span class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-primary-600 shrink-0">
                    <Check size={14} />
                  </span>
                  <p>{benefit}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
