---
import HeroProgram from '@/components/sections/HeroProgram.astro';
import ProgramFeatures from '@/components/sections/ProgramFeatures.astro';
import Layout from '@layouts/Layout.astro';
---

<Layout>
  <HeroProgram
    programa="Programa"
    titulo="Inglés en el Mundo"
    descripcion="El objetivo principal es que los estudiantes alcancen un nivel C1 en el Marco Común Europeo de Referencia para las lenguas."
    imagen="/assets/images/Banner_1.webp"
  />
  <ProgramFeatures
  title="Características principales del programa"
  features={[
    {
      title: "Modalidad Flexible",
      description: "Ofrecen cursos presenciales, semipresenciales y virtuales para adaptarse a las necesidades del cliente."
    },
    {
      title: "Metodología",
      description: "Se utiliza una metodología comunicativa y dinámica, con docentes capacitados."
    },
    {
      title: "Duración",
      description: "La duración total es de aproximadamente dos años (1000 horas), aunque esto puede variar según el nivel de ingreso del estudiante, determinado por un examen de clasificación inicial."
    },
    {
      title: "Estructura de Estudio",
      description: "El programa se divide en niveles desde A1 hasta C1, con un total de horas que varían entre 320 y 360 por cada dos niveles."
    },
    {
      title: "Certificación",
      description: "Se otorga certificación por cada nivel aprobado."
    }
  ]}
/>
</Layout>
