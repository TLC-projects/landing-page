---
export const prerender = false;
import HeroProgram from '@/components/sections/HeroProgram.astro';
import CoursesSection from '@/components/sections/CoursesSection.astro';
import Layout from '@layouts/Layout.astro';
import { getCoursesByProgram } from '@/lib/courses';

console.log('[SSR] Renderizando /programas/fundamentos');
const courses = await getCoursesByProgram('FUNDAMENTOS');
console.log(`[SSR] Cursos obtenidos: ${courses.length}`);

---

<Layout
  title="Fundamentos de la Enseñanza del Inglés en Colombia"
  description="Curso especializado en estándares, plan de estudios y evaluación para la enseñanza del inglés en Colombia. Formación para docentes según lineamientos del MEN."
  keywords="fundamentos enseñanza inglés, estándares MEN Colombia, plan estudios inglés, evaluación idiomas, formación docentes Colombia, TLC"
>
  <HeroProgram
    programa="Cursos de"
    titulo="Fundamentos de la Enseñanza del Inglés en Colombia:"
    descripcion="Programas de formación docente enfocado en el análisis de políticas educativas, estándares internacionales y estrategias de evaluación y acompañamiento pedagógico para fortalecer la enseñanza y la gestión educativa."
    imagen="/assets/images/Banner_4.webp"
    src="/audios/frances.mp3"
    reverse
  />

  <CoursesSection title="Cursos disponibles" courses={courses} />
</Layout>
