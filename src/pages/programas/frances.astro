---
import HeroProgram from '@/components/sections/HeroProgram.astro';
import ProgramFeatures from '@/components/sections/ProgramFeatures.astro';
import Layout from '@/layouts/Layout.astro';
import { Check } from 'lucide-react';

const benefits = [
  'Reconocer y utilizar vocabulario básico del francés académico.',
  'Comprender expresiones y estructuras lingüísticas simples.',
  'Participar en intercambios orales breves en francés con fines educativos.',
  'Leer textos cortos y guiados en lengua francesa.',
  'Producir mensajes escritos simples utilizando estructuras básicas del idioma.'
];

---

<Layout
  title="Programa de Francés"
  description="Aprende francés en TLC Colombia. Cursos desde nivel A1 hasta C1 del Marco Común Europeo. Certificación internacional DELF y metodología comunicativa moderna."
  keywords="curso de francés, aprender francés, francés A1 A2 B1 B2 C1, francés Colombia, certificación DELF, clases de francés, TLC francés"
>
  <HeroProgram
    programa="Programa"
    titulo="Programa Francés"
    descripcion="Programa de formación docente que introduce a los participantes en el aprendizaje académico del francés, fortaleciendo habilidades lingüísticas básicas para la comprensión y producción de mensajes en contextos educativos."
    imagen="/assets/images/Banner_2.webp"
    src='/audios/frances.mp3'
    reverse
  />

  <ProgramFeatures
    title="Características principales del programa"
    features={[
      {
        title: 'Descripción:',
        description: 'Este curso de formación docente de 20 horas introduce a los participantes en el aprendizaje académico del francés como lengua extranjera. El curso se enfoca en el desarrollo de habilidades lingüísticas básicas a través del estudio de vocabulario fundamental, estructuras gramaticales simples y funciones comunicativas elementales, aplicadas a contextos educativos. A lo largo del proceso formativo, los docentes fortalecen su comprensión y producción oral y escrita en francés, construyendo una base académica que les permita avanzar de manera progresiva en el aprendizaje del idioma.'
      },
      {
        title: 'Objetivo:',
        description:
          'Desarrollar competencias académicas básicas en lengua francesa que permitan a los docentes comprender y producir mensajes simples en contextos educativos.'
      }
    ]}
  />

<section class="bg-accent-600 dark:bg-accent-700 text-white" id="beneficios">
    <div class="u-wrapper md:pb-6 py-6 mx-auto">
      <div class="relative grid md:grid-cols-2 gap-10 items-center justify-items-center">
        <img
          src="/assets/images/img_beneficios.webp"
          alt="Imagen de información del programa"
          class="md:-mt-18 mt-0 w-md"
        />
        <div class="flex flex-col gap-4">
          <h2 class="text-3xl font-bold">Desempeños</h2>
          <p>Al finalizar el curso, el docente puede:</p>
          <ul class="space-y-5">
            {
              benefits.map((benefit) => (
                <li class="flex items-start gap-4">
                  <span class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-primary-600 shrink-0">
                    <Check size={14} />
                  </span>
                  <p>{benefit}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
