---
import Banner from '@/components/sections/Banner.astro';
import CoursesSection from '@/components/sections/CoursesSection.astro';
import ImageListSection from '@/components/sections/ImageListSection.astro';
import { Audio } from '@/components/ui';
import { getCoursesByProgram } from '@/lib/courses-service';
import Layout from '@layouts/Layout.astro';

const courses = await getCoursesByProgram('CAPACITACION_DOCENTE');
---

<Layout>
  <Audio a11y className="mx-auto" src="/assets/audio/conoce-mas.mp3" client:only />
  <!-- Parecido al Hero sin los botones, tambien tiene posicionamiento -->
  <Banner
    subtitle="Cursos"
    title="Capacitación docente"
    description="Lorem ipsum dolor sit amet consectetur adipisicing elit. Voluptas, doloremque."
    img="/assets/images/Banner_3.webp"
    side="right"
  />
  <!-- Seccion reutilizable de lista con imagen, intercambio de lados especificando el side -->
  <ImageListSection
    title="Nuestros Programas"
    img="/assets/images/img_nuestros_progrmas.webp"
    side="left"
    className="text-white bg-accent-600"
    items={[
      {
        subtitle: 'Programa de Idiomas',
        description:
          'Diseñado para desarrollar habilidades comunicativas prácticas y progresivas en contextos cotidianos, académicos y laborales.'
      },
      {
        subtitle: 'Cursos Libres de Formación de Docentes',
        description:
          'Cursos individuales de 20 horas en diversas áreas, como enseñanza de inglés para preescolar, uso de plataformas educativas y estrategias de aprendizaje autónomo.'
      },
      {
        subtitle: 'Preparación para Exámenes',
        description:
          'Cursos enfocados en habilidades y estrategias para presentar exámenes de inglés y de metodología de enseñanza.'
      },
      {
        subtitle: 'Servicios In-House',
        description: 'Cursos y seminarios para empresas, con tendencias innovadoras en formación.'
      }
    ]}
  />

  <!-- Seccion reutilizable de lista de cursos disponibles máx 6 -->
  <CoursesSection
    title="Cursos disponibles"
    courses={courses}
  >
    <p class="text-center text-lg w-3/4 mx-auto text-secondary-600 mt-12">
      Para obtener más información detallada, puede ponerse en contacto con nosotros a través de nuestro correo
      electrónico <a class="font-bold" href="mailto:servicliente@ceaitlc.com.co">servicliente@ceaitlc.com.co</a> o llamando
      al teléfono (601) 6333300 EXT 107
    </p>
  </CoursesSection>
</Layout>
